# RENIS-BI — copy to .env and adjust

# PostgreSQL (single server — databases: renis, keycloak, typo3)
POSTGRES_USER=renis
POSTGRES_PASSWORD=renis_dev_password
POSTGRES_DB=renis
DATABASE_URL=postgresql://renis:renis_dev_password@postgres:5432/renis

KEYCLOAK_DB_PASSWORD=keycloak_dev_password

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=renis
KEYCLOAK_CLIENT_ID=renis-management
KEYCLOAK_CLIENT_SECRET=change-me-in-production
KEYCLOAK_ISSUER=http://localhost:8080/realms/renis
KEYCLOAK_TYPO3_CLIENT_ID=renis-typo3
KEYCLOAK_TYPO3_CLIENT_SECRET=change-me-typo3-secret
# Server-side OIDC / JWKS from Docker containers
KEYCLOAK_INTERNAL_ISSUER=http://keycloak:8080/realms/renis
KEYCLOAK_ADMIN_URL=http://localhost:8080
KEYCLOAK_ADMIN_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_ADMIN_USER=admin

# Management app (UI + /api on port 3000)
AUTH_URL=http://localhost:3000
AUTH_SECRET=change-this-to-a-random-string-at-least-32-characters-long
MANAGEMENT_PUBLIC_URL=http://localhost:3000
# QR codes on PDFs always use MANAGEMENT_PUBLIC_URL/verify/{code} (see lib/verify-url.ts).
# TYPO3 public site (optional): TYPO3_BASE_URL=http://localhost:8082 — embed widget on /verify page
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8080/realms/renis
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=renis-management
CORS_ORIGIN=http://localhost:3000
WIDGET_PUBLIC_URL=http://localhost:3001
# Optional national ministry coat-of-arms in diploma PDF header (MinIO object key)
# MINISTRY_LOGO_OBJECT_KEY=branding/ministry-coat-of-arms.png

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=renis-documents
MINIO_PUBLIC_URL=http://localhost:9000

# SMTP (Mailhog in dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@renis.bi
SMTP_SECURE=false

# TYPO3 (PostgreSQL database `typo3` on the same server)
TYPO3_DB_NAME=typo3
TYPO3_DB_USER=typo3
TYPO3_DB_PASSWORD=typo3_dev_password
TYPO3_BASE_URL=http://localhost:8082
TYPO3_INSTALL_TOOL_PASSWORD=password
