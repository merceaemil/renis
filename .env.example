# RENIS-BI — copy to .env and adjust
#
# Everything is served through Traefik with TLS on these subdomains:
#   https://renis.arxia.com             → TYPO3 (public site)
#   https://management.renis.arxia.com  → Management Next.js (UI + /api)
#   https://widget.renis.arxia.com      → Verification widget bundle
#   https://auth.renis.arxia.com        → Keycloak (account, /admin, /realms/renis)
#   https://data.renis.arxia.com        → MinIO S3 endpoint + console
#
# Add these to /etc/hosts and trust the self-signed wildcard cert (or accept
# the browser warning each time):
#   127.0.0.1 renis.arxia.com management.renis.arxia.com widget.renis.arxia.com auth.renis.arxia.com data.renis.arxia.com

# PostgreSQL (single server — databases: renis, keycloak, typo3)
POSTGRES_USER=renis
POSTGRES_PASSWORD=renis_dev_password
POSTGRES_DB=renis
DATABASE_URL=postgresql://renis:renis_dev_password@postgres:5432/renis

KEYCLOAK_DB_PASSWORD=keycloak_dev_password

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=renis
KEYCLOAK_CLIENT_ID=renis-management
KEYCLOAK_CLIENT_SECRET=change-me-in-production
KEYCLOAK_ISSUER=https://auth.renis.arxia.com/realms/renis
KEYCLOAK_TYPO3_CLIENT_ID=renis-typo3
KEYCLOAK_TYPO3_CLIENT_SECRET=change-me-typo3-secret
# Server-side OIDC / JWKS calls from Docker containers
KEYCLOAK_INTERNAL_ISSUER=http://keycloak:8080/realms/renis
KEYCLOAK_ADMIN_URL=https://auth.renis.arxia.com
KEYCLOAK_ADMIN_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_ADMIN_USER=admin

# Management app (UI + /api at the same Next.js host)
AUTH_URL=https://management.renis.arxia.com
AUTH_SECRET=change-this-to-a-random-string-at-least-32-characters-long
MANAGEMENT_PUBLIC_URL=https://management.renis.arxia.com
# QR codes on PDFs always use MANAGEMENT_PUBLIC_URL/verify/{code} (see lib/verify-url.ts).
NEXT_PUBLIC_KEYCLOAK_ISSUER=https://auth.renis.arxia.com/realms/renis
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=renis-management
# Browser-side calls from TYPO3 (renis.arxia.com) and the widget demo to
# management.renis.arxia.com/api need this. Comma-separated list of allowed origins.
CORS_ORIGIN=https://renis.arxia.com,https://widget.renis.arxia.com
WIDGET_PUBLIC_URL=https://widget.renis.arxia.com
# Optional national ministry coat-of-arms in diploma PDF header (MinIO object key)
# MINISTRY_LOGO_OBJECT_KEY=branding/ministry-coat-of-arms.png

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=renis-documents
MINIO_PUBLIC_ENDPOINT=https://data.renis.arxia.com
MINIO_BROWSER_REDIRECT_URL=https://data.renis.arxia.com

# SMTP (Mailhog in dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@renis.bi
SMTP_SECURE=false

# TYPO3 (PostgreSQL database `typo3` on the same server)
TYPO3_DB_NAME=typo3
TYPO3_DB_USER=typo3
TYPO3_DB_PASSWORD=typo3_dev_password
TYPO3_BASE_URL=https://renis.arxia.com
TYPO3_INSTALL_TOOL_PASSWORD=password
